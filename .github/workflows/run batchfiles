name: Build and Package

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  run-batch-files:
    runs-on: windows-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.10"

      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install cffi

      - name: Run Build Script
        # Executes fasm and runs tests
        run: .\comp_dev.bat

      - name: Run Zip Script
        # Executes your packaging logic
        run: .\zip.bat

      - name: Upload Build Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: build-output
          path: |
            bf16/*.dll
            *.zip
